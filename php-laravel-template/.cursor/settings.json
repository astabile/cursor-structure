{
  "agent": {
    "allowedTools": [
      "read_file",
      "write_file",
      "edit_file",
      "search_files",
      "list_directory",
      "run_terminal_command"
    ],
    "disallowedCommands": [
      "git commit",
      "git push",
      "git push --force",
      "git reset --hard",
      "git rebase",
      "rm -rf",
      "migrate:fresh",
      "migrate:rollback",
      "db:wipe"
    ]
  },
  "contextFiles": [
    "conductor/product.md",
    "conductor/tech-stack.md",
    "conductor/workflow.md",
    "conductor/decisions.md"
  ]
}
